# OneChain RPC endpoint (Sui-compatible)
ONECHAIN_RPC_URL=https://rpc-testnet.onelabs.cc:443

# Wallet — Bech32 private key (suiprivkey...) or 64-char hex
PRIVATE_KEY=suiprivkey1q...

# AI providers — chain: Groq (primary) → Mistral (fallback) → safe hold
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# Agent behaviour
# DRY_RUN=true means the PTB is simulated but NOT submitted to chain
DRY_RUN=true
CRON_INTERVAL_SEC=60
GAS_BUDGET_MIST=10000000

# On-chain contract addresses (replace after deploying to OneChain)
# Both point to the same onenomad package
ONENOMAD_PACKAGE_ID=0x0
ONEDEX_PACKAGE_ID=0x0
ONEVAULT_PACKAGE_ID=0x0

# Position tracking object (created during setup)
POSITION_OBJECT_ID=0x0

# Pool object IDs (created during setup)
POOL_OCT_USDC_ID=0x0
POOL_OCT_USDT_ID=0x0
POOL_VAULT_STABLE_ID=0x0
POOL_VAULT_HIGH_ID=0x0
POOL_USDC_USDT_ID=0x0

# Dashboard server port
PORT=3000
